<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Background color -->
    <solid android:color="@android:color/white"/>

    <!-- Border -->
    <stroke
        android:width="1dp"
        android:color="#9E9E9E"/>

    <!-- Rounded corners -->
    <corners android:radius="10dp"/>

    <!-- Inner spacing -->
    <padding
        android:left="8dp"
        android:right="8dp"
        android:top="8dp"
        android:bottom="8dp"/>
</shape>