<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingTop="5dp">

        <RelativeLayout
            android:id="@+id/relay"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:layout_marginBottom="15dp"
            android:layout_marginLeft="7dp"
            android:layout_marginRight="7dp"
            android:layout_marginTop="2dp"
            android:background="@drawable/spinnr_back">

            <in.eoninfotech.eontechnician.view.MySearchableSpinner
                android:id="@+id/others_clients"
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:layout_centerVertical="true"
                android:layout_gravity="center"
                android:layout_marginLeft="5dp"
                android:gravity="center"
                android:spinnerMode="dialog" />

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentRight="true"
                android:layout_centerVertical="true"
                android:layout_gravity="center"
                android:layout_marginRight="6dp"
                android:src="@drawable/drop" />

        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="4dp"
            android:background="@drawable/linear_back"
            android:orientation="vertical"
            android:paddingBottom="15dp"
            android:paddingLeft="7dp"
            android:paddingRight="7dp"
            android:paddingTop="15dp">

            <in.eoninfotech.eontechnician.view.MyTextView
                android:id="@+id/text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VTS ID"
                android:textAllCaps="true" />

            <in.eoninfotech.eontechnician.view.MyEditText
               android:layout_below="@+id/text"
                android:id="@+id/other_device_id"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="2dp"
                android:hint=""
                android:inputType="number" />

            <ListView
                android:id="@+id/other_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:background="@drawable/et_frame"
                android:layout_margin="2dp">
            </ListView>

            <in.eoninfotech.eontechnician.view.MyTextView
                android:layout_above="@+id/other_remarks"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Remarks" />

            <in.eoninfotech.eontechnician.view.MyEditText
                android:id="@+id/other_remarks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="2dp"
                android:gravity="top|left"
                android:layout_alignParentBottom="true"
                android:hint=""
                android:lines="3" />

        </LinearLayout>

        <CheckBox
                android:id="@+id/check_tel_supprt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Telelphonic Support"
                android:textSize="19dp"
                android:textStyle="bold"/>
        <Button
                android:id="@+id/other_update"
                android:layout_width="match_parent"
                android:layout_height="35dp"
                android:layout_marginBottom="10dp"
                android:layout_marginLeft="4dp"
                android:layout_marginRight="4dp"
                android:layout_marginTop="15dp"
                android:background="@drawable/selector_update"
                android:gravity="center"
                android:layout_alignParentBottom="true"
                android:text="UPDATE"
                android:textColor="#ffffff"
                android:textSize="20dp" />

    </LinearLayout>
</ScrollView>