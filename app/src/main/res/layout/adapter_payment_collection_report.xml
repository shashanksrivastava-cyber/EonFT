<?xml version="1.0" encoding="utf-8"?>
<LinearLayout android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    xmlns:android="http://schemas.android.com/apk/res/android">

    <!--<android.support.v7.widget.CardView-->
        <!--android:layout_width="match_parent"-->
        <!--android:layout_height="wrap_content"-->
        <!--android:background="@color/eonWhite">-->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="5dp"
        android:background="@drawable/et_frame"
        android:elevation="2dp"
        android:orientation="vertical">

        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="@color/eonBlue"
            android:layout_marginLeft="10dp"
            android:layout_marginRight="10dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:orientation="horizontal"
            android:weightSum="3">

            <TextView
                android:id="@+id/date"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10dp"
                android:background="@color/eonBlue"
                android:paddingLeft="10dp"
                android:paddingRight="10dp"
                android:paddingTop="3dp"
                android:layout_gravity="center"
                android:gravity="center"
                android:paddingBottom="3dp"
                android:fontFamily="sans-serif-medium"
                android:text="Replacement"
                android:textColor="@color/eonWhite"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_weight="1"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.5"
                android:text="Client : "
                android:gravity="right"
                android:fontFamily="sans-serif-medium"
                android:textColor="#616161"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/clientName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="JK Lakshmi"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:maxLength="30"
                android:layout_marginRight="10dp"
                android:textColor="@color/colorAccent"
                android:textSize="12sp"
                android:layout_weight="1.7"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:orientation="horizontal"
            android:weightSum="3">

            <TextView
                android:id="@+id/dates"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginLeft="10dp"
                android:background="@color/eonWhite"
                android:paddingLeft="10dp"
                android:paddingRight="10dp"
                android:paddingTop="3dp"
                android:layout_gravity="center"
                android:gravity="center"
                android:fontFamily="sans-serif-medium"
                android:text="Replacement"
                android:textColor="@color/eonWhite"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_weight="1"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.6"
                android:text="Location : "
                android:gravity="right"
                android:fontFamily="sans-serif-medium"
                android:textColor="#616161"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/location"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="JK Lakshmi"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:maxLength="30"
                android:layout_marginRight="10dp"
                android:textColor="@color/colorAccent"
                android:textSize="12sp"
                android:layout_weight="1.7"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:layout_marginLeft="20dp"
            android:weightSum="2">

            <!--<TextView-->
                <!--android:layout_width="wrap_content"-->
                <!--android:layout_height="wrap_content"-->
                <!--android:layout_weight="0.5"-->
                <!--android:text="Location : "-->
                <!--android:layout_gravity="center"-->
                <!--android:gravity="center"-->
                <!--android:fontFamily="sans-serif-medium"-->
                <!--android:textColor="#616161"-->
                <!--android:textSize="12sp"-->
                <!--android:textStyle="bold" />-->
        <!--<TextView-->
            <!--android:id="@+id/location"-->
            <!--android:layout_width="wrap_content"-->
            <!--android:layout_height="wrap_content"-->
            <!--android:text="JK Lakshmi"-->
            <!--android:textStyle="bold"-->
            <!--android:fontFamily="sans-serif-medium"-->
            <!--android:maxLength="30"-->
            <!--android:layout_marginRight="10dp"-->
            <!--android:textColor="@color/colorAccent"-->
            <!--android:textSize="12sp"-->
            <!--android:layout_weight="1.7"/>-->

        </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/activity"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="10dp"
                    android:background="@color/eonBlue"
                    android:paddingLeft="10dp"
                    android:paddingRight="10dp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp"
                    android:text="DATE"
                    android:textColor="@color/eonWhite"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:visibility="gone"/>

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/greyed_out"
                android:layout_marginLeft="10dp"
                android:layout_marginRight="10dp"
                android:layout_marginTop="10dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:orientation="horizontal"
                android:layout_marginRight="30dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="10dp"
                    android:text="Amount : "
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium"
                    android:padding="5dp"/>

                <TextView
                    android:id="@+id/amount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="15000.00"
                    android:fontFamily="sans-serif-medium"
                    android:textSize="12sp"
                    android:padding="5dp"/>

                <ImageView
                    android:id="@+id/verified"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="right"
                    android:layout_marginLeft="10dp"/>

            </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="@color/greyed_out"
                    android:layout_marginLeft="5dp"
                    android:layout_marginRight="10dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="right"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="10dp"
                        android:text="Method : "
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium"
                        android:padding="5dp"/>

                    <TextView
                        android:id="@+id/method"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cheque"
                        android:fontFamily="sans-serif-small"
                        android:textSize="12sp"
                        android:padding="5dp"/>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!--</android.support.v7.widget.CardView>-->

</LinearLayout>