<?xml version="1.0" encoding="utf-8"?>
    <ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingTop="5dp">

        <RelativeLayout
            android:id="@+id/relay"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:layout_marginBottom="7dp"
            android:layout_marginLeft="7dp"
            android:layout_marginRight="7dp"
            android:layout_marginTop="2dp"
            android:background="@drawable/spinnr_back"
            android:visibility="visible">

            <in.eoninfotech.eontechnician.view.MySearchableSpinner
                android:id="@+id/old_s_client"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_gravity="center"
                android:layout_marginLeft="5dp"
                android:gravity="center"
                android:spinnerMode="dialog"
                android:visibility="visible"/>

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentRight="true"
                android:layout_centerVertical="true"
                android:layout_gravity="center"
                android:layout_marginRight="6dp"
                android:src="@drawable/drop" />

        </RelativeLayout>

        <ImageView
            android:id="@+id/upload_img"
            android:layout_width="125dp"
            android:layout_height="105dp"
            android:layout_gravity="center_horizontal"
            android:padding="2dp"
            android:layout_marginBottom="3dp"
            android:src="@drawable/add"
            android:background="@drawable/linear_back"
            android:visibility="visible"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="4dp"
            android:background="@drawable/linear_back"
            android:orientation="vertical"
            android:paddingBottom="15dp"
            android:paddingLeft="7dp"
            android:paddingRight="7dp"
            android:paddingTop="5dp">

            <in.eoninfotech.eontechnician.view.MyTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Device Info"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/old_device_id"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:layout_marginLeft="20dp"
                android:layout_marginRight="20dp"
                android:background="@drawable/et_frame"
                android:hint="OLD VTS ID"
                android:imeOptions="actionDone"
                android:inputType="text"
                android:paddingBottom="2dp"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:paddingTop="2dp"
                android:singleLine="true"
                android:textSize="14sp"
                android:layout_marginBottom="10dp"
                android:layout_marginTop="5dp"/>

            <EditText
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:layout_marginLeft="20dp"
                android:layout_marginRight="20dp"
                android:background="@drawable/et_frame"
                android:hint="NEW VTS ID"
                android:imeOptions="actionDone"
                android:inputType="text"
                android:paddingBottom="2dp"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:paddingTop="2dp"
                android:singleLine="true"
                android:textSize="14sp"
                android:layout_marginBottom="10dp"
                android:layout_marginTop="5dp"/>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="35dp"
                android:layout_marginLeft="10dp"
                android:layout_marginRight="5dp">

                <in.eoninfotech.eontechnician.view.MyTextView
                    android:id="@+id/new_deviceType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Device Type: "
                    android:layout_marginTop="2dp"
                    android:layout_marginLeft="10dp"
                    android:padding="5dp"/>

                <RadioGroup
                    android:id="@+id/radiodeviceType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_toRightOf="@+id/new_deviceType"
                    android:layout_marginLeft="5dp">

                    <RadioButton
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:checked="true"
                        android:text="Voice"
                        android:textSize="14sp" />

                    <RadioButton
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Non-Voice"
                        android:textSize="14sp"
                        android:layout_marginLeft="5dp"/>

                </RadioGroup>
            </RelativeLayout>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginBottom="10dp"
                android:layout_marginLeft="20dp"
                android:layout_marginRight="20dp"
                android:layout_marginTop="2dp"
                android:background="@drawable/spinnr_back">

                <in.eoninfotech.eontechnician.view.MySearchableSpinner
                    android:id="@+id/replace_reason"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_centerVertical="true"
                    android:layout_gravity="center"
                    android:layout_marginLeft="5dp"
                    android:gravity="center"
                    android:spinnerMode="dialog" />

                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="35dp"
                    android:layout_alignParentRight="true"
                    android:layout_centerVertical="true"
                    android:layout_gravity="center"
                    android:layout_marginRight="6dp"
                    android:src="@drawable/drop" />

            </RelativeLayout>

            <in.eoninfotech.eontechnician.view.MyEditText
                android:id="@+id/old_new_device_id"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="2dp"
                android:hint=""
                android:inputType="number"
                android:visibility="gone"/>

            <in.eoninfotech.eontechnician.view.MyTextView
                android:id="@+id/t_drs_id"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OLD DRS ID"
                android:textAllCaps="true"
                android:visibility="gone"/>

            <in.eoninfotech.eontechnician.view.MyEditText
                android:id="@+id/old_drs_id"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="2dp"
                android:hint=""
                android:inputType="number"
                android:visibility="gone"/>

            <in.eoninfotech.eontechnician.view.MyTextView
                android:id="@+id/t_drs_old"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="New DRS Id"
                android:textAllCaps="true"
                android:visibility="gone"/>

            <in.eoninfotech.eontechnician.view.MyEditText
                android:id="@+id/old_new_drs_id"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="2dp"
                android:hint=""
                android:inputType="number"
                android:visibility="gone"/>

            <EditText
                android:id="@+id/old_remarks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="20dp"
                android:layout_marginRight="20dp"
                android:background="@drawable/et_frame"
                android:hint="Remarks"
                android:inputType="text|textMultiLine"
                android:paddingBottom="2dp"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:paddingTop="2dp"
                android:textSize="14sp"
                android:gravity="top|left"
                android:lines="4"/>
        </LinearLayout>

        <Button
            android:id="@+id/old_update"
            android:layout_width="match_parent"
            android:layout_height="35dp"
            android:layout_marginBottom="10dp"
            android:layout_marginLeft="4dp"
            android:layout_marginRight="4dp"
            android:layout_marginTop="15dp"
            android:background="@drawable/selector_update"
            android:gravity="center"
            android:text="UPDATE"
            android:textColor="#ffffff"
            android:textSize="20dp" />
    </LinearLayout>
</ScrollView>
