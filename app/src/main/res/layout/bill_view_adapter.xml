<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center"
    android:orientation="horizontal">

    <TextView
        android:id="@+id/date"
        android:layout_width="70dp"
        android:layout_height="wrap_content"
        android:layout_marginLeft="10dp"
        android:layout_marginRight="5dp"
        android:padding="5dp"
        android:textColor="@color/black"
        android:textSize="16dp"/>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/lStart"
            android:layout_width="2dp"
            android:layout_height="10dp"
            android:background="@color/black"
            android:layerType="software" />

        <TextView
            android:id="@+id/txtCount"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/round_full"
            android:gravity="center"
            android:padding="5dp"
            android:textAllCaps="true"
            android:textColor="@color/eonWhite"
            android:textSize="16dp" />

        <ImageView
            android:id="@+id/lEnd"
            android:layout_width="2dp"
            android:layout_height="25dp"
            android:layerType="software"
            android:src="@drawable/vertical_line" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/et_frame"
        android:orientation="vertical"
        android:layout_marginRight="10dp"
        android:layout_marginLeft="5dp">

        <TextView
            android:id="@+id/bill_no"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:padding="7dp"
            android:text="B123456789"
            android:textColor="@color/black"
            android:textStyle="bold" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/greyed_out" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/amount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:drawableLeft="@drawable/ic_rupee_small"
                android:padding="5dp"
                android:text="5000" />

            <TextView
                android:id="@+id/status"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="right"
                android:layout_weight="1"
                android:gravity="right"
                android:padding="5dp"
                android:text="Approved"
                android:textColor="@color/green"
                android:textStyle="bold"
                android:layout_marginRight="7dp"/>


        </LinearLayout>

    </LinearLayout>
</LinearLayout>