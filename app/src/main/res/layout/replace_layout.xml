<?xml version="1.0" encoding="utf-8"?>
<LinearLayout android:id="@+id/linearReplacement"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    android:orientation="vertical"
    android:visibility="gone"
    android:background="@color/eonWhite"
    xmlns:android="http://schemas.android.com/apk/res/android">

    <android.support.v7.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

        <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="30dp"
        android:layout_marginRight="5dp"
        android:layout_marginTop="5dp"
        android:weightSum="4">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="What is Replaced? "
            android:layout_marginTop="2dp"
            android:textColor="@color/colorPrimary"
            android:textSize="12sp"
            android:padding="5dp"
            android:layout_weight="1"
            android:layout_gravity="center"/>

        <RadioGroup
            android:id="@+id/radioGroup"
            android:layout_width="wrap_content"
            android:layout_height="25dp"
            android:orientation="horizontal"
            android:layout_toRightOf="@+id/replace_deviceType"
            android:layout_marginLeft="5dp"
            android:layout_weight="3"
            android:layout_marginTop="2dp">

            <RadioButton
                android:id="@+id/radioVTS"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:checked="true"
                android:text="VTS"
                android:textSize="14sp" />

            <RadioButton
                android:id="@+id/radioDRS"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="DRS"
                android:textSize="14sp"
                android:layout_marginLeft="5dp"/>

            <RadioButton
                android:id="@+id/radioBoth"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Both"
                android:textSize="14sp"
                android:layout_marginLeft="5dp"/>

        </RadioGroup>

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginLeft="15dp"
        android:layout_marginRight="15dp"
        android:background="@color/grey500"
        android:layout_marginTop="10dp"
        android:visibility="gone"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginLeft="10dp"
                android:layout_marginRight="5dp"
                android:weightSum="4">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Device Type"
                    android:textSize="15sp"
                    android:textColor="@color/colorPrimary"
                    android:padding="5dp"
                    android:layout_weight="2.5"
                    android:layout_gravity="center_vertical"
                    android:layout_marginLeft="5dp"/>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_marginLeft="10dp"
                    android:layout_marginTop="3dp"
                    android:layout_weight="1.7"
                    android:background="@drawable/et_frame">

                    <Spinner
                        android:id="@+id/vltddeviceReplace"
                        android:layout_width="match_parent"
                        android:layout_height="35dp"
                        android:layout_centerVertical="true"
                        android:layout_gravity="center"
                        android:layout_marginLeft="5dp"
                        android:gravity="center"
                        android:entries="@array/spinnerItems"
                        android:spinnerMode="dropdown" />

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="35dp"
                        android:layout_alignParentRight="true"
                        android:layout_centerVertical="true"
                        android:layout_gravity="center"
                        android:layout_marginRight="6dp"
                        android:background="@color/eonWhite"
                        android:src="@drawable/baseline_keyboard_arrow_down_black_24" />

                </RelativeLayout>


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:layout_weight="2">

                    <RadioGroup
                        android:id="@+id/radiovltdDevicetype"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_weight="1.5"
                        android:weightSum="3">

                        <RadioButton
                            android:id="@+id/old"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Old"
                            android:checked="true"
                            android:textSize="14sp"/>

                        <RadioButton
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="VLTD"
                            android:textSize="14sp" />
                    </RadioGroup>
                </LinearLayout>

            </LinearLayout>

    <LinearLayout
        android:id="@+id/linearvts"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="4">

        <android.support.design.widget.TextInputLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <EditText android:id="@+id/old_deviceidreplace"
                android:layout_width="150dp"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:hint="Old Device ID"
                android:singleLine="true"
                android:layout_weight="2"
                android:textSize="12sp"
                android:layout_marginLeft="10dp"
                android:maxLength="20"/>
        </android.support.design.widget.TextInputLayout>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
        <android.support.design.widget.TextInputLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <EditText android:id="@+id/new_deviceid"
                android:layout_width="150dp"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:hint="New Device ID"
                android:singleLine="true"
                android:layout_weight="2"
                android:textSize="12sp"
                android:text=""
                android:layout_marginLeft="10dp"
                android:maxLength="20"/>
        </android.support.design.widget.TextInputLayout>

        <ProgressBar
            android:id="@+id/progressReplace"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_alignParentRight="true"
            android:layout_marginRight="20dp"
            android:layout_marginTop="15dp"
            android:visibility="gone"/>
        <ImageView
            android:id="@+id/idExistReplace"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_circle_black_24dp"
            android:layout_alignParentRight="true"
            android:layout_marginTop="15dp"
            android:layout_marginRight="20dp"
            android:visibility="gone"/>

        <ImageView
            android:id="@+id/idnotExistReplace"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_cancel_black_24dp"
            android:layout_alignParentRight="true"
            android:layout_marginTop="15dp"
            android:layout_marginRight="20dp"
            android:visibility="gone"/>
        </RelativeLayout>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2">

        <android.support.design.widget.TextInputLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <EditText android:id="@+id/regNo"
                android:layout_width="150dp"
                android:layout_height="wrap_content"
                android:hint="Reg No."
                android:singleLine="true"
                android:layout_weight="2"
                android:textSize="12sp"
                android:layout_marginLeft="10dp"
                android:maxLength="20"
                android:digits="0123456789*,QWERTYUIOPASDFGHJKLZXCVBNM"
                android:inputType="textCapCharacters"/>
        </android.support.design.widget.TextInputLayout>

        <android.support.design.widget.TextInputLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <EditText android:id="@+id/rep_srNo"
                android:layout_width="150dp"
                android:layout_height="wrap_content"
                android:hint="VTS Full Sr. No.(e.g. E124-36-EAN-R02-7974)"
                android:singleLine="true"
                android:layout_weight="2"
                android:textSize="12sp"
                android:layout_marginLeft="10dp"
                android:maxLength="50"/>
        </android.support.design.widget.TextInputLayout>


        <TextView
            android:visibility="gone"
            android:id="@+id/plantName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:singleLine="true"
            android:textSize="12sp"
            android:layout_marginLeft="10dp"
            android:layout_marginRight="10dp"
            android:layout_weight="1"
            android:layout_gravity="bottom"
            android:layout_marginBottom="5dp"/>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="30dp"
        android:layout_marginLeft="10dp"
        android:layout_marginRight="5dp"
        android:layout_marginTop="5dp"
        android:weightSum="5"
        android:visibility="gone">

        <in.eoninfotech.eontechnician.view.MyTextView
            android:id="@+id/replace_deviceType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Device Type: "
            android:layout_marginTop="2dp"
            android:textSize="12sp"
            android:padding="5dp"
            android:layout_weight="3.5"/>

        <RadioGroup
            android:layout_width="wrap_content"
            android:layout_height="25dp"
            android:orientation="horizontal"
            android:layout_toRightOf="@+id/replace_deviceType"
            android:layout_marginLeft="5dp"
            android:layout_weight="2">

            <RadioButton
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:checked="true"
                android:text="Voice"
                android:textSize="14sp" />

            <RadioButton
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Non-Voice"
                android:textSize="14sp"
                android:layout_marginLeft="5dp"/>

        </RadioGroup>
    </LinearLayout>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginBottom="10dp"
        android:layout_marginTop="2dp"
        android:background="@drawable/et_frame"
        android:layout_marginLeft="10dp"
        android:layout_marginRight="10dp">

        <in.eoninfotech.eontechnician.view.MySearchableSpinner
            android:id="@+id/replace_reason"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_centerVertical="true"
            android:layout_gravity="center"
            android:gravity="center"
            android:spinnerMode="dialog" />

        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="35dp"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:layout_gravity="center"
            android:layout_marginRight="6dp"
            android:background="@color/eonWhite"
            android:src="@drawable/baseline_keyboard_arrow_down_black_24" />
    </RelativeLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/drsReplace"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="2dp"
        android:visibility="gone">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="25dp"
        android:layout_marginLeft="10dp"
        android:layout_marginRight="5dp"
        android:visibility="gone"
        android:layout_marginTop="2dp"
        android:weightSum="5">

        <in.eoninfotech.eontechnician.view.MyTextView
            android:id="@+id/replace_drs"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Is DRS Replace? "
            android:layout_marginTop="2dp"
            android:layout_weight="0.7"
            android:layout_gravity="center"/>

        <RadioGroup
            android:id="@+id/radiodrsReplace"
            android:layout_width="wrap_content"
            android:layout_height="25dp"
            android:orientation="horizontal"
            android:layout_toRightOf="@+id/replace_drs"
            android:layout_marginLeft="5dp"
            android:layout_gravity="center"
            android:layout_weight="2">

            <RadioButton
                android:id="@+id/nodrsReplace"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="3.5"
                android:text="No"
                android:checked="true"
                android:textSize="14sp"
                android:layout_marginLeft="5dp"/>

            <RadioButton
                android:id="@+id/radioyesdrsReplace"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Yes"
                android:textSize="14sp" />

        </RadioGroup>

    </LinearLayout>

        <android.support.design.widget.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/t_drs_vts_id">
            <EditText android:id="@+id/drs_vts_id"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:hint="VTS ID"
                android:singleLine="true"
                android:layout_weight="1"
                android:textSize="12sp"
                android:layout_marginLeft="10dp"
                android:layout_marginRight="10dp"
                android:maxLength="20"
                android:visibility="gone"/>
        </android.support.design.widget.TextInputLayout>

        <android.support.design.widget.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/t_drs_veh_no">
            <EditText android:id="@+id/drs_veh_no"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Vehicle Reg No."
                android:singleLine="true"
                android:layout_weight="1"
                android:textSize="12sp"
                android:layout_marginLeft="10dp"
                android:layout_marginRight="10dp"
                android:maxLength="20"
                android:digits="0123456789*,QWERTYUIOPASDFGHJKLZXCVBNM"
                android:inputType="textCapCharacters"
                android:visibility="gone"/>
        </android.support.design.widget.TextInputLayout>

    <android.support.design.widget.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/t_old_drsid"
        android:visibility="visible">
        <EditText android:id="@+id/old_drsid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:hint="Old DRS ID"
            android:singleLine="true"
            android:layout_weight="1"
            android:textSize="12sp"
            android:layout_marginLeft="10dp"
            android:layout_marginRight="10dp"
            android:visibility="visible"
            android:digits="0123456789*,qwertzuiopasdfghjklyxcvbnm"/>
    </android.support.design.widget.TextInputLayout>


<android.support.design.widget.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/tnew_drsid"
        android:visibility="visible">
        <EditText android:id="@+id/new_drsid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:hint="New DRS ID"
            android:singleLine="true"
            android:layout_weight="1"
            android:textSize="12sp"
            android:layout_marginLeft="10dp"
            android:layout_marginRight="10dp"
            android:visibility="visible"
            android:digits="0123456789*,qwertzuiopasdfghjklyxcvbnm"/>
    </android.support.design.widget.TextInputLayout>

    <LinearLayout
        android:id="@+id/relaydrsTypeReplace"
        android:layout_width="match_parent"
        android:layout_height="30dp"
        android:layout_marginLeft="5dp"
        android:layout_marginRight="5dp"
        android:visibility="gone"
        android:weightSum="5">

        <TextView
            android:id="@+id/new_drs_dircrep"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DRS Direction :"
            android:layout_marginTop="5dp"
            android:layout_marginLeft="5dp"
            android:textColor="@color/eonBlue"
            android:layout_weight="3.2"/>

        <RadioGroup
            android:id="@+id/radiodireplace"
            android:layout_width="wrap_content"
            android:layout_height="25dp"
            android:orientation="horizontal"
            android:layout_toRightOf="@+id/new_drs_dircrep"
            android:layout_marginLeft="5dp"
            android:layout_weight="1">

            <RadioButton
                android:id="@+id/replacenormal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="Normal"
                android:textSize="14sp"
                android:layout_weight="1"/>

            <RadioButton
                android:id="@+id/replacereverse"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reverse"
                android:textSize="14sp"
                android:layout_marginLeft="5dp"
                android:layout_weight="1"/>

        </RadioGroup>
    </LinearLayout>
    </LinearLayout>

        </LinearLayout>
    </android.support.v7.widget.CardView>

    <CheckBox
        android:id="@+id/magnet_set"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Magnet Set Changed"
        android:visibility="gone"/>

</LinearLayout>