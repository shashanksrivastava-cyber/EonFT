<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto">

<ScrollView
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activity.StockActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <RelativeLayout
            android:id="@+id/relay"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginLeft="20dp"
            android:layout_marginRight="20dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="5dp"
            android:background="@drawable/et_frame">

            <in.eoninfotech.eontechnician.view.MySearchableSpinner
                android:id="@+id/m_region"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_gravity="center"
                android:layout_marginLeft="5dp"
                android:gravity="center"
                android:spinnerMode="dialog"
                android:visibility="visible"/>

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="35dp"
                android:layout_alignParentRight="true"
                android:layout_centerVertical="true"
                android:layout_gravity="center"
                android:layout_marginRight="6dp"
                android:background="@color/eonWhite"
                android:src="@drawable/baseline_keyboard_arrow_down_black_24" />

        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <in.eoninfotech.eontechnician.view.MyTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Date -->"
                android:textStyle="bold" />

            <in.eoninfotech.eontechnician.view.MyTextView
                android:id="@+id/datee"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="18/11/2016" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="1dp"
            android:background="@drawable/linear_back"
            android:orientation="vertical"
            android:padding="7dp">

            <in.eoninfotech.eontechnician.view.MyTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Working VTS"
                android:textStyle="bold" />

            <in.eoninfotech.eontechnician.view.MyTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/qty" />

            <in.eoninfotech.eontechnician.view.MyEditText
                android:id="@+id/working_vts_qty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="2dp"
                android:hint="" />

            <in.eoninfotech.eontechnician.view.MyTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/srno" />

            <in.eoninfotech.eontechnician.view.MyEditText
                android:id="@+id/working_vts_srno"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="2dp"
                android:hint="Serial No. should comma seperated"
                android:textColorHint="@color/greyed_out"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="1dp"
            android:background="@drawable/linear_back"
            android:orientation="vertical"
            android:padding="7dp">

            <in.eoninfotech.eontechnician.view.MyTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Faulty VTS"
                android:textStyle="bold" />

            <in.eoninfotech.eontechnician.view.MyTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/qty" />

            <in.eoninfotech.eontechnician.view.MyEditText
                android:id="@+id/faulty_vts_qty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="2dp"
                android:hint="" />

            <in.eoninfotech.eontechnician.view.MyTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/srno" />

            <in.eoninfotech.eontechnician.view.MyEditText
                android:id="@+id/faulty_vts_srno"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="2dp"
                android:hint="Serial No. should comma seperated"
                android:textColorHint="@color/greyed_out"/>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/drs_lay_on"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="1dp"
            android:background="@drawable/linear_back"
            android:orientation="vertical"
            android:padding="7dp">

            <in.eoninfotech.eontechnician.view.MyTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Cables"
                android:textStyle="bold" />

            <in.eoninfotech.eontechnician.view.MyTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Drs Cable " />

            <in.eoninfotech.eontechnician.view.MyEditText
                android:id="@+id/cable_7_meter"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="2dp"
                android:hint="" />

            <in.eoninfotech.eontechnician.view.MyTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Power Cable" />

            <in.eoninfotech.eontechnician.view.MyEditText
                android:id="@+id/cable_2_meter"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="2dp"
                android:hint=""/>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/drs_lay_two"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="1dp"
            android:background="@drawable/linear_back"
            android:orientation="vertical"
            android:padding="7dp">

            <in.eoninfotech.eontechnician.view.MyTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Drum Sensor"
                android:textStyle="bold" />

            <in.eoninfotech.eontechnician.view.MyTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Working DRS Quantity" />

            <in.eoninfotech.eontechnician.view.MyEditText
                android:id="@+id/drum_sensor_qty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="2dp"
                android:hint="" />

            <in.eoninfotech.eontechnician.view.MyTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Serial No"
                android:visibility="gone"/>

            <in.eoninfotech.eontechnician.view.MyEditText
                android:id="@+id/drum_sensor_id"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="2dp"
                android:hint="Id's should comma seperated"
                android:textColorHint="@color/greyed_out"
                android:visibility="gone"/>

            <in.eoninfotech.eontechnician.view.MyTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Faulty DRS Quantity" />

            <in.eoninfotech.eontechnician.view.MyEditText
                android:id="@+id/faulty_drs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="2dp"
                android:hint=""
                android:textColorHint="@color/greyed_out" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/drs_lay_th"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="1dp"
            android:background="@drawable/linear_back"
            android:orientation="vertical"
            android:padding="7dp">

            <in.eoninfotech.eontechnician.view.MyTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Magnet Set" />

            <in.eoninfotech.eontechnician.view.MyEditText
                android:id="@+id/magnet_set"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="2dp"
                android:hint="" />

            <in.eoninfotech.eontechnician.view.MyTextView
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Y Cable" />

            <in.eoninfotech.eontechnician.view.MyEditText
                android:visibility="gone"
                android:id="@+id/y_cable"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="2dp"
                android:hint="" />

            <in.eoninfotech.eontechnician.view.MyTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Remarks" />

            <in.eoninfotech.eontechnician.view.MyEditText
                android:id="@+id/remarks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="2dp"
                android:gravity="top|left"
                android:hint=""
                android:lines="4" />
        </LinearLayout>
        <LinearLayout
            android:id="@+id/vts_lay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="1dp"
            android:background="@drawable/linear_back"
            android:orientation="vertical"
            android:padding="7dp">

            <in.eoninfotech.eontechnician.view.MyTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Power Cable" />

            <in.eoninfotech.eontechnician.view.MyEditText
                android:id="@+id/power_cable"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="2dp"
                android:hint="" />

            <in.eoninfotech.eontechnician.view.MyTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Remarks" />

            <in.eoninfotech.eontechnician.view.MyEditText
                android:id="@+id/vts_remarks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="2dp"
                android:gravity="top|left"
                android:hint=""
                android:lines="4" />
        </LinearLayout>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/update_data"
            style="@style/Widget.Material3.Button.ElevatedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Update Data"
            android:layout_marginTop="10dp"
            android:layout_marginLeft="10dp"
            android:layout_marginRight="10dp"
            android:backgroundTint="@color/colorPrimary"
            android:textColor="@color/eonWhite"
            android:textSize="16sp"
            app:elevation="12dp" />
    </LinearLayout>

</ScrollView>

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:layout_gravity="center_vertical|center_horizontal"
            android:indeterminate="false"
            android:max="100"
            android:clickable="true"
            android:progress="20"/>

</RelativeLayout>
