<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginLeft="10dp"
        android:layout_marginRight="10dp"
        android:layout_marginTop="20dp">

        <android.support.v7.widget.CardView
            android:id="@+id/cardView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="35dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Technician of The Month"
                android:textSize="20sp"
                android:textColor="#FF9800"
                android:layout_marginTop="20dp"/>

            <TextView
                android:id="@+id/technician_month"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="1dp"
                android:text=""
                android:textColor="#FF9800"
                android:textSize="20sp" />

            <RelativeLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp">

                <de.hdodenhof.circleimageview.CircleImageView
                    xmlns:app="http://schemas.android.com/apk/res-auto"
                    android:id="@+id/ivProfile"
                    android:layout_width="130dp"
                    android:layout_height="130dp"
                    android:elevation="5dp"
                    android:scaleType="centerCrop"
                    android:padding="5dp"
                    android:clickable="true"
                    app:civ_border_color="@color/greyed_out"
                    app:civ_border_width="1dp"
                    android:src="@drawable/user_circle"/>

                <ProgressBar
                    android:id="@+id/progressBars"
                    style="?android:attr/progressBarStyleSmall"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:visibility="visible"
                    android:layout_centerHorizontal="true"
                    android:layout_centerVertical="true"
                    android:layout_marginTop="30dp"/>

            </RelativeLayout>

                <TextView
                    android:id="@+id/tech_name"
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:textSize="24dp"
                    android:text=""
                    android:gravity="center"
                    android:textColor="#4CAF50"
                    android:layout_marginTop="10dp"/>

                <TextView
                    android:id="@+id/tech_loc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="3dp"
                    android:layout_marginTop="3dp"
                    android:textSize="24dp"
                    android:gravity="center"
                    android:textColor="#4CAF50"
                    android:text="" />

            <pl.droidsonroids.gif.GifImageView
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:src="@drawable/july_shot"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="You have earned INR 1000"
                android:textSize="14sp"
                android:textColor="@color/eonBlue"
                android:layout_marginTop="10dp"/>

            <TextView
                android:id="@+id/viewMore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@color/eonBlue"
                android:text="Previous Winners"
                android:textSize="14sp"
                android:elevation="5dp"
                android:padding="5dp"
                android:textColor="@color/eonWhite"
                android:layout_marginTop="10dp"/>

        </LinearLayout>

        </android.support.v7.widget.CardView>

    </FrameLayout>

    <ImageView
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:layout_gravity="top|start"
        android:src="@drawable/badge"/>

    <TextView
            android:layout_height="40dp"
            android:layout_width="40dp"
            android:layout_gravity="top|right"
            android:id="@+id/txtclose"
            android:background="@drawable/ic_cross_black_24dp"/>

</FrameLayout>