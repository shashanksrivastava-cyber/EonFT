<?xml version="1.0" encoding="utf-8"?>
<LinearLayout android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    xmlns:android="http://schemas.android.com/apk/res/android">

    <android.support.v7.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:elevation="5dp"
        app:cardCornerRadius="5dp"
        android:layout_margin="5dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="5dp"
        android:background="@color/eonWhite"
        android:elevation="2dp"
        android:orientation="vertical">

    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="@color/eonBlue"
        android:layout_marginLeft="10dp"
        android:layout_marginRight="10dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:orientation="horizontal"
        android:weightSum="3">

        <TextView
            android:id="@+id/workType"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp"
            android:background="@color/eonBlue"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:text="Replacement"
            android:textColor="@color/eonWhite"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_weight="1"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.8"
            android:text="Client : "
            android:gravity="right"
            android:textColor="#616161"
            android:textSize="12sp"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/clientName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="123456"
            android:textStyle="bold"
            android:maxLength="30"
            android:layout_marginRight="10dp"
            android:textColor="@color/colorAccent"
            android:textSize="12sp"
            android:layout_weight="1.7"/>

    </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/activity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10dp"
                android:background="@color/eonBlue"
                android:paddingLeft="10dp"
                android:paddingRight="10dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:text="DATE"
                android:textColor="@color/eonWhite"
                android:textSize="12sp"
                android:textStyle="bold"
                android:visibility="gone"/>
        </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/image"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:srcCompat="@drawable/ic_build_black_24dp"
                    android:padding="5dp"
                    android:layout_gravity="center_vertical"
                    android:layout_marginLeft="5dp"/>

            <TextView
                android:id="@+id/data"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10dp"
                android:paddingRight="10dp"
                android:text="DATE"
                android:textSize="14sp"
                android:padding="10dp"/>

            </LinearLayout>

        </LinearLayout>

        <TextView
            android:id="@+id/textViewAttached"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="View Attached Document"
            android:textColor="@color/colorPrimary"
            android:layout_gravity="right"
            android:layout_marginRight="10dp"
            android:textSize="12sp"
            android:drawableLeft="@drawable/clip"
            android:visibility="gone"
            android:gravity="center"
            android:layout_marginBottom="5dp"/>

