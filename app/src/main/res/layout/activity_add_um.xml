<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <RelativeLayout
        android:id="@+id/profile_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/eonBlue"
        android:elevation="4dp"
        android:paddingBottom="2dp"
        app:layout_constraintBaseline_toTopOf="parent">

        <View
            android:id="@+id/view1"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/eonWhite"
            android:layout_marginTop="8dp" />

        <LinearLayout
            android:id="@+id/abc"
            android:layout_width="match_parent"
            android:layout_height="30dp"
            android:orientation="horizontal"
            android:layout_marginTop="5dp"
            android:weightSum="2"
            android:layout_below="@+id/view1">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="horizontal"
                android:weightSum="1">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_marginLeft="5dp"
                    android:layout_marginRight="5dp"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="2dp"
                    android:elevation="7dp">

                        <RelativeLayout
                            android:id="@+id/relay"
                            android:layout_width="match_parent"
                            android:layout_height="40dp">

                            <in.eoninfotech.eontechnician.view.MySearchableSpinner
                                android:id="@+id/main_client"
                                android:layout_width="match_parent"
                                android:layout_height="40dp"
                                android:layout_centerVertical="true"
                                android:layout_gravity="center"
                                android:layout_marginStart="5dp"
                                android:gravity="center"
                                android:spinnerMode="dialog"/>

                            <ImageView
                                android:layout_width="wrap_content"
                                android:layout_height="20dp"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:layout_gravity="center"
                                android:layout_marginEnd="6dp"
                                android:background="@color/eonWhite"
                                android:src="@drawable/baseline_keyboard_arrow_down_black_24" />

                        </RelativeLayout>

                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <View android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="@color/eonWhite"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="horizontal"
                android:weightSum="2">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_marginLeft="5dp"
                    android:layout_marginRight="5dp"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="2dp"
                    android:elevation="7dp">

                        <RelativeLayout
                            android:id="@+id/relayLocation"
                            android:layout_width="match_parent"
                            android:layout_height="40dp">

                            <in.eoninfotech.eontechnician.view.MySearchableSpinner
                                android:id="@+id/new_in_clients"
                                android:layout_width="match_parent"
                                android:layout_height="40dp"
                                android:layout_centerVertical="true"
                                android:layout_gravity="center"
                                android:layout_marginStart="5dp"
                                android:gravity="center"
                                android:spinnerMode="dialog"/>

                            <ImageView
                                android:layout_width="wrap_content"
                                android:layout_height="20dp"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:layout_gravity="center"
                                android:layout_marginEnd="6dp"
                                android:background="@color/eonWhite"
                                android:src="@drawable/baseline_keyboard_arrow_down_black_24" />

                        </RelativeLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

        </LinearLayout>

        <View
            android:id="@+id/view2"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/eonWhite"
            android:layout_marginTop="5dp"
            android:layout_below="@+id/abc"/>

        <LinearLayout
            android:id="@+id/abcd"
            android:layout_width="match_parent"
            android:layout_height="30dp"
            android:orientation="horizontal"
            android:layout_marginTop="5dp"
            android:layout_marginBottom="5dp"
            android:weightSum="2"
            android:layout_below="@+id/view2">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="horizontal"
                android:weightSum="1">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_marginLeft="5dp"
                    android:layout_marginRight="5dp"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="2dp"
                    android:elevation="7dp">

                        <RelativeLayout
                            android:id="@+id/relays"
                            android:layout_width="match_parent"
                            android:layout_height="40dp">

                            <in.eoninfotech.eontechnician.view.MySearchableSpinner
                                android:id="@+id/new_in_locations"
                                android:layout_width="match_parent"
                                android:layout_height="40dp"
                                android:layout_centerVertical="true"
                                android:layout_gravity="center"
                                android:layout_marginStart="5dp"
                                android:gravity="center"
                                android:spinnerMode="dialog"/>

                            <ImageView
                                android:layout_width="wrap_content"
                                android:layout_height="20dp"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:layout_gravity="center"
                                android:layout_marginEnd="6dp"
                                android:background="@color/eonWhite"
                                android:src="@drawable/baseline_keyboard_arrow_down_black_24" />

                        </RelativeLayout>

                </androidx.cardview.widget.CardView>
            </LinearLayout>

        </LinearLayout>

    </RelativeLayout>

    <com.google.android.material.button.MaterialButton
        style="@style/Widget.MaterialComponents.Button.Icon"
        android:id="@+id/submit"
        android:layout_height="wrap_content"
        android:layout_width="match_parent"
        android:layout_gravity="top|start"
        android:layout_marginTop="5dp"
        android:layout_marginStart="5dp"
        android:layout_marginEnd="5dp"
        android:visibility="visible"
        android:text="@string/get_vehicles_under_maint"
        app:layout_constraintTop_toBottomOf="@+id/profile_layout"/>

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/submit"
        app:layout_constraintBottom_toTopOf="@id/cardFaultDetail"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="5dp"
            android:layout_margin="7dp">

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/txt_content_unavailable"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:text="@string/content_unavailable"
                android:visibility="gone" />

            <in.eoninfotech.eontechnician.NonScrollListView
                android:id="@+id/device_detail_list_receive"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10dp"
                android:layout_marginRight="10dp"
                android:layout_marginBottom="10dp" />
        </LinearLayout>
    </ScrollView>

    <androidx.cardview.widget.CardView
        android:id="@+id/cardFaultDetail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/eonWhite"
        app:cardCornerRadius="10dp"
        app:layout_constraintBottom_toTopOf="@id/add_veh_um"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/faultDetail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/eonWhite"
            android:orientation="vertical"
            android:padding="10dp"
            android:visibility="visible">

            <in.eoninfotech.eontechnician.CustomTextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="10dp"
                android:hint="Contact Person Name">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/faultPersonName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:drawableLeft="@drawable/ic_user"
                    android:drawablePadding="5dp"
                    android:inputType="text"
                    android:maxLength="20"
                    android:singleLine="true"
                    android:textSize="14sp" />
            </in.eoninfotech.eontechnician.CustomTextInputLayout>

            <in.eoninfotech.eontechnician.CustomTextInputLayout
                android:id="@+id/pass"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Contact Person Phone No">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/faultPersonNumber"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:drawableStart="@drawable/ic_phone_call"
                    android:drawableLeft="@drawable/ic_phone_call"
                    android:drawablePadding="10dp"
                    android:inputType="number"
                    android:maxLength="10"
                    android:singleLine="true"
                    android:textSize="14sp" />
            </in.eoninfotech.eontechnician.CustomTextInputLayout>

            <EditText
                android:id="@+id/new_in_remarks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:background="@drawable/et_frame"
                android:gravity="top|start"
                android:hint="Remarks"
                android:inputType="textCapWords|textMultiLine"
                android:lines="4"
                android:overScrollMode="always"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:scrollbarStyle="insideInset"
                android:scrollbars="vertical"
                android:textSize="14sp"
                android:autofillHints="Remarks" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <com.google.android.material.button.MaterialButton
        style="@style/Widget.MaterialComponents.Button.Icon"
        android:id="@+id/add_veh_um"
        android:layout_height="wrap_content"
        android:layout_width="match_parent"
        android:layout_gravity="top|start"
        android:layout_marginTop="5dp"
        android:layout_marginStart="5dp"
        android:layout_marginEnd="5dp"
        android:visibility="visible"
        android:text="@string/add_vehicle_um"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>